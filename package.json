{
  "name": "nextjs-template-ts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run i18n:lint && next dev",
    "build": "npm run i18n:lint && next build",
    "prod": "npm run build && npm run start",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "i18n:types": "typesafe-i18n --no-watch",
    "i18n:watch": "typesafe-i18n",
    "i18n:check": "tsc --noEmit",
    "i18n:lint": "npm run i18n:types && npm run i18n:check"
  },
  "engines": {
    "node": "24.14.1"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "antd": "^6.3.6",
    "axios": "^1.15.2",
    "next": "^16.2.4",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "prettier": "^3.8.3",
    "typesafe-i18n": "^5.27.1",
    "typescript": "^6"
  }
}
